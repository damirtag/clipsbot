TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
DATABASE_URL=postgres://postgres:password@localhost:5432/mellclipsbot?sslmode=disable

# Your numeric Telegram user ID (not username). Only this user can use
# admin commands / have messages staged for import. Get it via @userinfobot.
ADMIN_USER_ID=

# Numeric chat ID of a private channel/chat the bot is an admin of, used
# purely as durable storage for processed clip file_ids. Create a private
# channel, add the bot as admin, forward any message from it to
# @userinfobot / @RawDataBot to get the chat ID (looks like -100xxxxxxxxxx).
STORAGE_CHAT_ID=

PROCESSING_VERSION=1
WATERMARK_TEXT=@mellclipsbot
FFMPEG_PATH=ffmpeg
TEMP_DIR=/tmp/mellclipsbot
